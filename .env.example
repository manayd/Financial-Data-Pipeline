# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# PostgreSQL
DATABASE_URL=postgresql://pipeline:localdev@localhost:5432/financial_data

# S3 / MinIO (local dev)
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=financial-data-lake
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1

# Producer config
PRODUCER_TYPE=fake

# Consumer config (Week 4)
CONSUMER_TYPE=console
S3_SINK_BATCH_SIZE=100
S3_SINK_FLUSH_INTERVAL=60

# Alpha Vantage (Week 2)
ALPHA_VANTAGE_API_KEY=
ALPHA_VANTAGE_POLL_INTERVAL=300
WATCHLIST_TICKERS=AAPL,MSFT,GOOGL,AMZN,TSLA

# SEC EDGAR (Week 2)
SEC_EDGAR_POLL_INTERVAL=600
SEC_EDGAR_USER_AGENT=FinancialDataPipeline/1.0 (your-email@example.com)

# LLM (Week 5)
# Provider options: openai, anthropic, bedrock
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# For bedrock: use model ID like anthropic.claude-sonnet-4-20250514-v1:0
LLM_MODEL_ID=gpt-4o-mini
LLM_REQUESTS_PER_MINUTE=50
LLM_MAX_RETRIES=3
LLM_CONTENT_MAX_CHARS=3000

# Infrastructure deployment (Week 6) — copy to .env.infra
# INFRA_PROJECT_NAME=financial-data-pipeline
# INFRA_ENVIRONMENT=dev
# INFRA_AWS_REGION=us-east-1
# INFRA_DB_INSTANCE_CLASS=db.t3.micro
# INFRA_MSK_INSTANCE_TYPE=kafka.t3.small
